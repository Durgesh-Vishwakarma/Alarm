generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alarm {
  id           String            @id
  userId       String?           @map("user_id")
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  label        String
  time         String
  repeatDays   String[]          @map("repeat_days")
  challengeId  String            @map("challenge_id")
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  wakeHistory  WakeHistory[]
  results      ChallengeResult[]

  @@map("alarms")
  @@index([userId], name: "idx_alarms_user_id")
  @@index([isActive], name: "idx_alarms_active")
  @@index([createdAt], name: "idx_alarms_created_at")
}

model WakeHistory {
  id       BigInt   @id @default(autoincrement())
  alarmId  String?  @map("alarm_id")
  alarm    Alarm?   @relation(fields: [alarmId], references: [id], onDelete: SetNull)
  userId   String?  @map("user_id")
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  wokeAt   DateTime @default(now()) @map("woke_at")
  success  Boolean
  xp       Int      @default(0)

  @@map("wake_history")
  @@index([userId], name: "idx_wake_history_user_id")
  @@index([alarmId], name: "idx_wake_history_alarm_id")
  @@index([wokeAt], name: "idx_wake_history_woke_at")
  @@index([success], name: "idx_wake_history_success")
}

model ChallengeResult {
  id          BigInt   @id @default(autoincrement())
  alarmId     String?  @map("alarm_id")
  alarm       Alarm?   @relation(fields: [alarmId], references: [id], onDelete: SetNull)
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  challengeId String   @map("challenge_id")
  success     Boolean
  confidence  Decimal  @db.Decimal(4, 3)
  provider    String?
  reason      String?
  labels      Json
  metadata    Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("challenge_results")
  @@index([userId], name: "idx_challenge_results_user_id")
  @@index([alarmId], name: "idx_challenge_results_alarm_id")
  @@index([challengeId], name: "idx_challenge_results_challenge_id")
  @@index([success], name: "idx_challenge_results_success")
  @@index([createdAt], name: "idx_challenge_results_created_at")
  @@index([provider], name: "idx_challenge_results_provider")
  @@index([labels], type: Gin, name: "idx_challenge_results_labels")
}

model User {
  id          String            @id @default(uuid())
  email       String?           @unique
  googleSub   String?           @unique @map("google_sub")
  displayName String?           @map("display_name")
  photoUrl    String?           @map("photo_url")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  settings    Settings?
  alarms      Alarm[]
  wakeHistory WakeHistory[]
  results     ChallengeResult[]

  @@map("users")
  @@index([email], name: "idx_users_email")
}

model Settings {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strictness            String   @default("Strict")
  timezone              String?  
  notificationsEnabled  Boolean  @default(true) @map("notifications_enabled")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
